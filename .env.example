# Nexphoria Environment Variables
# Copy to .env.local and fill in

# Optional: Webhook URL for new waitlist signups (e.g. n8n, Zapier, Make)
WAITLIST_WEBHOOK_URL=

# Optional: Webhook URL for new contact form submissions
CONTACT_WEBHOOK_URL=

# Site URL (used for og tags and sitemap)
NEXT_PUBLIC_SITE_URL=https://nexphoria.com
